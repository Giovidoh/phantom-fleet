{
  "name": "phantom-fleet-compile",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:24",
  "postCreateCommand": "curl --proto '=https' --tlsv1.2 -LsSf https://raw.githubusercontent.com/midnightntwrk/compact/main/install.sh | sh && echo 'export PATH=\"$HOME/.compact/bin:$PATH\"' >> ~/.bashrc",
  "customizations": {
    "vscode": {
      "extensions": ["midnightntwrk.compact"]
    }
  }
}
